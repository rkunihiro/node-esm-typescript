{
    "name": "esm-typescript",
    "version": "1.0.0",
    "description": "",
    "keywords": [],
    "author": "",
    "license": "ISC",
    "engines": {
        "node": "^20.15.0",
        "npm": "^10.7.0"
    },
    "type": "module",
    "main": "dist/main.mjs",
    "source": "src/main.ts",
    "scripts": {
        "typecheck": "tsc -p . --noEmit",
        "lint": "eslint ./src && prettier -l ./src",
        "fix": "eslint --fix ./src && prettier -w ./src",
        "dev": "node --import=./ts-node-esm.mjs --env-file=.env.local --watch --watch-path=src src/main.ts",
        "prebuild": "rm -rf dist/*",
        "build": "node build.mjs",
        "start": "node --enable-source-maps --env-file=.env.local dist/main.mjs"
    },
    "devDependencies": {
        "@types/node": "^20.14.7",
        "@typescript-eslint/eslint-plugin": "^7.13.1",
        "@typescript-eslint/parser": "^7.13.1",
        "esbuild": "^0.21.5",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-import-resolver-typescript": "^3.6.1",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-unicorn": "^54.0.0",
        "prettier": "^3.3.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.5.2"
    }
}
